# Copy file này thành .env và điền thông tin thực tế
SERVER_URL=http://192.168.1.100        # IP của server Laravel trên mạng LAN
DEVICE_TOKEN=your_device_token_here   # Token lấy từ trang quản lý thiết bị

MIN_CONFIDENCE=0.50       # Ngưỡng nhận diện (0.0 – 1.0), tăng lên nếu nhiều nhận nhầm
COOLDOWN_SECONDS=300      # Không ghi lại cùng 1 người trong 5 phút

CAMERA_INDEX=0            # 0 = camera mặc định, thay đổi nếu dùng USB cam thứ 2
FRAME_WIDTH=640
FRAME_HEIGHT=480
PROCESS_EVERY_N=3         # Xử lý 1 trong 3 frame để giảm tải CPU

PING_INTERVAL_SECONDS=60  # Heartbeat mỗi 60 giây
DB_PATH=local_attendance.db
